---
// src/pages/index.astro
import '../styles/global.css';
import { Image } from 'astro:assets';

// Petición inicial al servidor Node
const response = await fetch('http://localhost:3000/api/libros?q=economia&max=10');
const libros = await response.json() as Array<{ id: string; titulo: string; autor: string; portada: string; descripcion: string; linkLectura: string; paginas: number }>;
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Book Explorer AI</title>
    <script is:inline>
        const temaGuardado = localStorage.getItem('tema');
        const prefiereOscuro = window.matchMedia('(prefers-color-scheme: dark)').matches;

        if (temaGuardado === 'dark' || (!temaGuardado && prefiereOscuro)) {
            document.documentElement.classList.add('dark');
        }
    </script>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen dark:bg-slate-900 dark:text-slate-50">
    <main class="max-w-6xl mx-auto px-4 py-12">
        
        <header class="text-center mb-16">
            <h1 class="text-6xl font-black tracking-tight bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent mb-4">
                Book Explorer
            </h1>
            <p class="text-slate-500 dark:text-slate-300 font-medium mb-4">Arquitectura: Node.js + Astro + Tailwind</p>
            <div class="flex justify-center gap-3">
                <button class="px-4 py-2 rounded-lg border border-slate-300 bg-white text-slate-700 font-semibold hover:bg-slate-100 transition-colors dark:bg-slate-800 dark:text-slate-100 dark:border-slate-600 dark:hover:bg-slate-700" id="modo-dark">Modo oscuro</button>
                <button class="px-4 py-2 rounded-lg border border-slate-300 bg-white text-slate-700 font-semibold hover:bg-slate-100 transition-colors dark:bg-slate-800 dark:text-slate-100 dark:border-slate-600 dark:hover:bg-slate-700" id="modo-light">Modo claro</button>
            </div>
        </header>
    
        <div class="bg-white dark:bg-slate-800 p-2 rounded-2xl shadow-xl shadow-slate-200/60 dark:shadow-slate-950/40 mb-12 flex flex-col md:flex-row gap-2 border border-slate-100 dark:border-slate-700">
            <input 
                type="text" 
                id="buscador" 
                placeholder="¿Qué quieres leer hoy? (ej. Python, Historia...)" 
                class="flex-1 px-6 py-4 rounded-xl text-slate-700 dark:text-slate-100 dark:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all font-medium"
            />
            
            <div class="flex items-center px-4 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-100 dark:border-slate-700">
                <label for="cantidad" class="text-xs font-bold uppercase text-slate-400 dark:text-slate-300 mr-3">Mostrar</label>
                <input 
                    type="number" 
                    id="cantidad" 
                    value="10" 
                    min="1" 
                    max="40" 
                    class="bg-transparent font-bold text-indigo-600 dark:text-indigo-300 w-12 focus:outline-none"
                />
            </div>
            
            <button 
                id="btnBuscar" 
                class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-xl font-bold transition-all hover:shadow-lg active:scale-95"
            >
                Buscar Libros
            </button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-6" id="contenedor-libros">
            {libros.map((libro) => (
                <div class="group bg-white dark:bg-slate-800 rounded-2xl p-4 border border-slate-100 dark:border-slate-700 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-2 flex flex-col items-center">
                    <div class="relative overflow-hidden rounded-lg mb-4 shadow-md bg-slate-100 dark:bg-slate-700 w-full">
                        <Image 
                            src={libro.portada || 'https://via.placeholder.com/150x220?text=No+Portada'} 
                            alt={libro.titulo} 
                            width={150} 
                            height={220}
                            quality="mid"
                            class="h-64 object-cover transform group-hover:scale-110 transition-transform duration-500"
                        />
                    </div>
                    <h3 class="font-bold text-sm leading-tight text-center line-clamp-2 mb-2 group-hover:text-indigo-600 transition-colors h-10 dark:text-slate-100">
                        {libro.titulo}
                    </h3>
                    <p class="text-xs text-slate-400 dark:text-slate-300 font-medium italic">{libro.autor}</p>
                    <p class="text-xs text-slate-400 dark:text-slate-300 font-medium italic">{libro.descripcion}</p>
                    <p class="text-xs text-slate-400 dark:text-slate-300 font-medium italic">Páginas: {libro.paginas}</p>
                    <a href={libro.linkLectura} target="_blank" class="text-indigo-600 dark:text-indigo-300 hover:underline text-xs mt-2">Leer más</a>
                </div>
            ))}
        </div>
    </main>

    <script>
        const btn = document.querySelector('#btnBuscar') as HTMLButtonElement;
        const inputTema = document.querySelector('#buscador') as HTMLInputElement;
        const inputMax = document.querySelector('#cantidad') as HTMLInputElement;
        const contenedor = document.querySelector('#contenedor-libros') as HTMLDivElement;
        const btnModoDark = document.querySelector('#modo-dark') as HTMLButtonElement;
        const btnModoLight = document.querySelector('#modo-light') as HTMLButtonElement;

        const setTema = (tema: 'dark' | 'light') => {
            const esOscuro = tema === 'dark';
            document.documentElement.classList.toggle('dark', esOscuro);
            localStorage.setItem('tema', tema);
        };

        btnModoDark.addEventListener('click', () => {
            setTema('dark');
        });

        btnModoLight.addEventListener('click', () => {
            setTema('light');
        });

        const realizarBusqueda = async () => {
            const tema = inputTema.value || 'economia';
            const max = inputMax.value || '10';

            btn.innerText = 'Buscando...';
            btn.disabled = true;
            btn.classList.add('opacity-50', 'cursor-not-allowed');

            try {
                const res = await fetch(`http://localhost:3000/api/libros?q=${encodeURIComponent(tema)}&max=${max}`);
                const nuevosLibros = await res.json();
                
                contenedor.innerHTML = nuevosLibros.map((l: any) => `
                    <div class="group bg-white dark:bg-slate-800 rounded-2xl p-4 border border-slate-100 dark:border-slate-700 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-2 flex flex-col items-center">
                        <div class="relative overflow-hidden rounded-lg mb-4 shadow-md bg-slate-100 dark:bg-slate-700 w-full">
                            <img src="${l.portada || 'https://via.placeholder.com/150x220?text=No+Portada'}" alt="${l.titulo}" class="w-full h-64 object-cover transform group-hover:scale-110 transition-transform duration-500" />
                        </div>
                        <h3 class="font-bold text-sm leading-tight text-center line-clamp-2 mb-2 group-hover:text-indigo-600 transition-colors h-10 dark:text-slate-100">${l.titulo}</h3>
                        <p class="text-xs text-slate-400 dark:text-slate-300 font-medium italic">${l.autor || 'Autor desconocido'}</p>
                        <p class="text-xs text-slate-400 dark:text-slate-300 font-medium italic">${l.descripcion || ''}</p>
                        <p class="text-xs text-slate-400 dark:text-slate-300 font-medium italic">Páginas: ${l.paginas ?? 'N/D'}</p>
                        <a href="${l.linkLectura || '#'}" target="_blank" class="text-indigo-600 dark:text-indigo-300 hover:underline text-xs mt-2">Leer más</a>
                    </div>
                `).join('');
            } catch (error) {
                console.error("Error en la conexión:", error);
                alert("¿Encendiste el servidor de Node? (npm run dev o node server.js)");
            } finally {
                btn.innerText = 'Buscar Libros';
                btn.disabled = false;
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
            }
        };

        // Escuchar click
        btn.addEventListener('click', realizarBusqueda);

        // Escuchar tecla Enter
        inputTema.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') realizarBusqueda();
        });
    </script>
</body>
</html>